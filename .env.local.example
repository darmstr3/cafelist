# ── Supabase ──────────────────────────────────────────────────
# Get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Google Places API ─────────────────────────────────────────
# Required for importing spots from Google + review-based scoring
# 1. Go to: https://console.cloud.google.com
# 2. Enable "Places API (New)" (NOT the legacy Places API)
# 3. Create an API key and restrict it to Places API
# Cost: ~$17/1000 Place Detail calls + $32/1000 Text Search calls
# A full NYC import of 200 spots costs ~$10
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── /labs (experimental agentic discovery) ────────────────────
# Required to power the /labs route. Without this, calls to
# /api/labs/recommend will return a fatal trace with the error
# "ANTHROPIC_API_KEY is not set". The rest of the app keeps working.
# Get a key from https://console.anthropic.com.
# Default model is claude-haiku-4-5; a typical run costs ~$0.001.
ANTHROPIC_API_KEY=your-anthropic-api-key-here
