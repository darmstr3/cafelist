# ── Supabase ──────────────────────────────────────────────────
# Get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Google Places API ─────────────────────────────────────────
# Required for importing spots from Google + review-based scoring
# 1. Go to: https://console.cloud.google.com
# 2. Enable "Places API (New)" (NOT the legacy Places API)
# 3. Create an API key and restrict it to Places API
# Cost: ~$17/1000 Place Detail calls + $32/1000 Text Search calls
# A full NYC import of 200 spots costs ~$10
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Scout agent (server-only) ─────────────────────────────────
# Shared secret used by the Scout scheduled task to authenticate
# against /api/scout. Generate one with:
#   node -e "console.log('scout_' + require('crypto').randomBytes(24).toString('hex'))"
# In production this MUST be set on Vercel — the route fails closed
# (500) if it's missing in prod.
SCOUT_CRON_SECRET=your-random-scout-cron-secret-here

# ── Admin gate (server-only) ──────────────────────────────────
# HTTP Basic Auth credentials used by middleware.ts to gate
# /admin/* and mutating /api/spots,/api/reviews,/api/import.
# The middleware fails CLOSED in production if ADMIN_PASSWORD is
# missing, so this MUST be configured on Vercel before deploy.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(18).toString('base64url'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-random-admin-password-here

# ── /labs (experimental agentic discovery) ────────────────────
# Required to power the /labs route. Without this, calls to
# /api/labs/recommend will return a fatal trace with the error
# "ANTHROPIC_API_KEY is not set". The rest of the app keeps working.
# Get a key from https://console.anthropic.com.
# Default model is claude-haiku-4-5; a typical run costs ~$0.001.
ANTHROPIC_API_KEY=your-anthropic-api-key-here
